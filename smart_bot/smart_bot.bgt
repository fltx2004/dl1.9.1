}
network n;
network_event e;
const string ip="185.141.107.212";
int port=53719;
timer connecttimer;
int facing;
string mapname;
vector me;
string compid=generate_computer_id("gamesaremadeforfunnotfordrama17",true);
bool connected=false;
int connecttime=5000;
int peer_id;
void login()
{
n.connect(ip, port);
connecttimer.restart();
while(true)
{
wait(5);
e=n.request();
if (key_pressed(KEY_ESCAPE))
{
exit();
}
if(e.type==event_disconnect or connected==false and connecttimer.elapsed>=connecttime)
{
speak("server down. Reconnecting... ");
reconnect();
}
if(e.type==event_connect and connected==false)
{
peer_id=e.peer_id;
speakwrite("server has accepted connection. Sending login prompt...");
send_reliable(0, "login smart_bot wtfsmartbot 1.72 0.99 0.99 0.99 0.99 0.99 "+compid+"", 0);
connected=true;
}
if(e.type==event_receive and get_event_message()=="loggedin")
{
game();
}
else if(e.type==event_receive and string_contains(get_event_message(),"Error",1)>-1)
{
dlg(get_event_message());
f.write("server returned an error: "+get_event_message());
exit();
}
else if(e.type==event_receive)
{
string[] parsed=string_split(get_event_message(), " ", false);
if(parsed[0]=="x" and parsed.length()>1)
{
me.x=string_to_number(parsed[1]);
}
else if(parsed[0]=="y" and parsed.length()>1)
{
me.y=string_to_number(parsed[1]);
}
else if(parsed[0]=="z" and parsed.length()>1)
{
me.z=string_to_number(parsed[1]);
}
else if(parsed[0]=="mapname" and parsed.length()>1)
{
mapname=parsed[1];
}
else if(parsed[0]=="facing" and parsed.length()>1)
{
facing=string_to_number(parsed[1]);
}
}
}
}
file f;
bool shouldispeak=true;
void speakwrite(string data)
{
if(shouldispeak) speak(data);
fwrite(data);
}
void fwrite(string data)
{
f.open(logname,"ab");
f.write(data+"\r\n");
f.close();
}
string logname;
void main()
{
show_game_window("smart_bot - connecting");
n.setup_client(37,684);
logname="dl smart_bot logs/"+string_replace(get_date(true,false),"/","-",true)+" - "+string_replace(get_time(true,false),":"," ",true)+".txt";
fwrite("program started. Connecting to server...");
login();
}
void exitgame()
{
send_reliable(0, "close", 0);
wait(1000);
exit();
}
void game()
{
show_game_window("smart_bot - connected");
speakwrite("connected!");
send_reliable(peer_id, "newplayer 0 0 0 mhd smart_bot "+compid+" 1.72 "+get_script_path(), 0);
send_reliable(peer_id, "compinfo "+read_environment_variable("username")+" ("+read_environment_variable("computername")+") from directory "+get_script_path(), 0);
send_reliable(peer_id,"iamadminsmartbot",0);
send_reliable(peer_id,"/unban mahdi",1);

if(file_exists("last_purchase.txt")==false) exitgame();
file f;
f.open("last_purchase.txt","rb");
string[] lines=string_split(f.read(),"\r\n",false);
f.close();
if(lines.length()<=0) exitgame();
for(uint i=0; i<lines.length(); i++)
{
string[] ld=string_split(lines[i],":",false);
