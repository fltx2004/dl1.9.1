void getruns()
{
runs=get_from_url("http://mahdiabedi.com/dl/dl.txt");
}
string get_from_url(string url)
{
http httpn;
httpn.user_agent="dl";
string what=httpn.get(url);
while(httpn.progress)
{
what+=httpn.request();
wait(5);
} return what;
}
